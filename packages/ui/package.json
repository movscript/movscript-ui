{
  "name": "@movscript/ui",
  "version": "0.1.0",
  "description": "MovScript React UI primitives.",
  "sideEffects": [
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": ">=18.3 <20",
    "react-dom": ">=18.3 <20"
  },
  "devDependencies": {
    "@movscript/tokens": "workspace:*",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
